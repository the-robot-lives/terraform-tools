#!/usr/bin/env bash
# migrate-tfstate — Adds S3 backend config to a module and migrates its state.
#
# Usage:
#   ./utils/migrate-tfstate terraform/production/services/eks
#   ./utils/migrate-tfstate terraform/production/database
#   ./utils/migrate-tfstate --dry-run terraform/production/iam
#   ./utils/migrate-tfstate --upload terraform/production/iam
#
# Prerequisites:
#   - terraform/production/state must be applied first
#   - Module must have a local terraform.tfstate

set -euo pipefail

BUCKET="${K8_TF_STATE_BUCKET:-}"
REGION="${K8_AWS_REGION:-us-east-1}"
PROFILE="${K8_AWS_PROFILE:-terraformer}"
KMS_ALIAS="${K8_TF_KMS_ALIAS:-}"
DYNAMO_TABLE="${K8_TF_LOCK_TABLE:-terraform-lock}"

DRY_RUN=false
AUTO_APPROVE=false

while [[ "${1:-}" == --* ]]; do
  case "$1" in
    --dry-run)  DRY_RUN=true; shift ;;
    --upload)   AUTO_APPROVE=true; shift ;;
    *) echo "Unknown flag: $1" >&2; exit 1 ;;
  esac
done

MODULE_DIR="${1:?Usage: migrate-tfstate [--dry-run] [--upload] <module-dir>}"

if [[ ! -d "$MODULE_DIR" ]]; then
  echo "Error: $MODULE_DIR is not a directory" >&2
  exit 1
fi

if [[ ! -f "$MODULE_DIR/terraform.tfstate" ]]; then
  echo "Error: No local terraform.tfstate in $MODULE_DIR" >&2
  exit 1
fi

# Derive S3 key from module path (strip leading terraform/)
S3_KEY="${MODULE_DIR#terraform/}/terraform.tfstate"

BACKEND_FILE="$MODULE_DIR/backend.tf"

if [[ -f "$BACKEND_FILE" ]]; then
  echo "Warning: $BACKEND_FILE already exists, skipping file creation" >&2
else
  cat > "$BACKEND_FILE" <<EOF
terraform {
  backend "s3" {
    bucket         = "$BUCKET"
    key            = "$S3_KEY"
    region         = "$REGION"
    profile        = "$PROFILE"
    encrypt        = true
    kms_key_id     = "$KMS_ALIAS"
    dynamodb_table = "$DYNAMO_TABLE"
  }
}
EOF
  echo "Created $BACKEND_FILE (key=$S3_KEY)"
fi

if $DRY_RUN; then
  echo "[dry-run] Would run: terraform -chdir=$MODULE_DIR init -migrate-state"
  exit 0
fi

echo "Migrating state for $MODULE_DIR ..."
if $AUTO_APPROVE; then
  echo "yes" | terraform -chdir="$MODULE_DIR" init -migrate-state
else
  terraform -chdir="$MODULE_DIR" init -migrate-state
fi
echo "Done. State for $MODULE_DIR is now in s3://$BUCKET/$S3_KEY"
